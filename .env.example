# ============ DATABASE (PostgreSQL + PgBouncer) ============
# Runtime via PgBouncer (transaction pooling). WAJIB ?pgbouncer=true agar
# Prisma menonaktifkan prepared statements (tak kompatibel transaction mode).
DATABASE_URL="postgresql://jaga:jaga_dev_pwd@localhost:6432/jagasekolah?pgbouncer=true"
# Koneksi LANGSUNG ke Postgres (bukan via pooler) — dipakai `prisma migrate`/`db push`/seed.
DIRECT_URL="postgresql://jaga:jaga_dev_pwd@localhost:5432/jagasekolah"
# Provider aktif (advisory lock & fitur Postgres lain menyala).
DATABASE_PROVIDER="postgresql"
# Kredensial container Postgres (dipakai docker-compose).
POSTGRES_USER="jaga"
POSTGRES_PASSWORD="jaga_dev_pwd"
POSTGRES_DB="jagasekolah"
# Produksi: arahkan DATABASE_URL ke PgBouncer terkelola, DIRECT_URL ke primary.
# Tambah pool tuning di DATABASE_URL bila perlu: &connection_limit=20&pool_timeout=20

# ============ AUTH ============
AUTH_SECRET="ganti-string-acak-min-32-char"
AUTH_URL="http://localhost:3000"
# Google OAuth (opsional — kosongkan untuk menonaktifkan tombol Google di /login)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============ SEED / AKUN DEMO ============
# Email & password default tiap role saat `prisma db seed` (data sintetis, BUKAN produksi).
# Email — fallback ke "<role>@demo.test" bila kosong.
SEED_EMAIL_SUPERADMIN=""
SEED_EMAIL_DINAS=""
SEED_EMAIL_KEPSEK=""
SEED_EMAIL_GURU=""
SEED_EMAIL_GURU2=""
SEED_EMAIL_BK=""
# Password — prioritas: SEED_PASSWORD_<ROLE> -> SEED_PASSWORD -> "password123".
SEED_PASSWORD=""                 # fallback untuk semua role
SEED_PASSWORD_SUPERADMIN=""
SEED_PASSWORD_DINAS=""
SEED_PASSWORD_KEPSEK=""
SEED_PASSWORD_GURU=""             # dipakai guru & guru2
SEED_PASSWORD_BK=""

# ============ ENKRIPSI PII (ENVELOPE) ============
# Master key membungkus data-key. WAJIB di produksi. 64-char hex (32 byte) disarankan.
PII_MASTER_KEY=""
# (legacy) fallback bila PII_MASTER_KEY kosong:
PII_ENCRYPTION_KEY=""

# ============ RATE LIMIT ============
RATE_LIMIT_MAX="30"
RATE_LIMIT_WINDOW_MS="60000"
AUTH_RATE_LIMIT_MAX="5"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
# Produksi multi-instance: set REDIS_URL untuk rate-limit terdistribusi.
REDIS_URL=""

# ============ RETENTION (UU PDP) ============
RETENTION_SISWA_HARI="730"   # 2 tahun setelah nonaktif
RETENTION_AUDIT_HARI="1825"  # 5 tahun
RETENTION_SYNC_HARI="90"

# ============ ML SERVICE (fase 2, opsional) ============
ML_SERVICE_URL=""

# IconScout API (opsional — untuk script fetch-icons build-time)
ICONSCOUT_CLIENT_ID=
ICONSCOUT_CLIENT_SECRET=
