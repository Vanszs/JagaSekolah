# ============ DATABASE ============
# MVP/demo: SQLite. Produksi nasional: PostgreSQL.
DATABASE_URL="file:./dev.db"
# Set "postgresql" di produksi agar advisory lock aktif.
DATABASE_PROVIDER="sqlite"
# Produksi (contoh):
# DATABASE_URL="postgresql://user:pass@host:5432/jagasekolah?schema=public&connection_limit=20&pool_timeout=20"
# DATABASE_PROVIDER="postgresql"

# ============ AUTH ============
AUTH_SECRET="ganti-string-acak-min-32-char"
AUTH_URL="http://localhost:3000"
# Google OAuth (opsional — kosongkan untuk menonaktifkan tombol Google di /login)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============ SEED / AKUN DEMO ============
# Password default tiap role saat `prisma db seed` (data sintetis, BUKAN produksi).
# Prioritas: SEED_PASSWORD_<ROLE> -> SEED_PASSWORD -> "password123".
# Email demo: super@ dinas@ kepsek@ guru@ guru2@ bk@ demo.test
SEED_PASSWORD=""                 # fallback untuk semua role
SEED_PASSWORD_SUPERADMIN=""
SEED_PASSWORD_DINAS=""
SEED_PASSWORD_KEPSEK=""
SEED_PASSWORD_GURU=""             # dipakai guru@ & guru2@
SEED_PASSWORD_BK=""

# ============ ENKRIPSI PII (ENVELOPE) ============
# Master key membungkus data-key. WAJIB di produksi. 64-char hex (32 byte) disarankan.
PII_MASTER_KEY=""
# (legacy) fallback bila PII_MASTER_KEY kosong:
PII_ENCRYPTION_KEY=""

# ============ RATE LIMIT ============
RATE_LIMIT_MAX="30"
RATE_LIMIT_WINDOW_MS="60000"
AUTH_RATE_LIMIT_MAX="5"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
# Produksi multi-instance: set REDIS_URL untuk rate-limit terdistribusi.
REDIS_URL=""

# ============ RETENTION (UU PDP) ============
RETENTION_SISWA_HARI="730"   # 2 tahun setelah nonaktif
RETENTION_AUDIT_HARI="1825"  # 5 tahun
RETENTION_SYNC_HARI="90"

# ============ ML SERVICE (fase 2, opsional) ============
ML_SERVICE_URL=""

# IconScout API (opsional — untuk script fetch-icons build-time)
ICONSCOUT_CLIENT_ID=
ICONSCOUT_CLIENT_SECRET=
